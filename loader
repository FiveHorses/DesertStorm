-- [[ 2. CORE LOGIC ]] --

-- Re-evaluates a specific container whenever an item changes or streams in
local function evaluateContainer(container)
    if not container then return end
    
    local slotsFolder = container:FindFirstChild("Slots")
    if not slotsFolder then return end

    local foundItems = {}
    local highestPriority = 0
    local bestColor = Color3.fromRGB(255, 255, 255)

    -- Scan current slots
    for _, slot in ipairs(slotsFolder:GetChildren()) do
        local itemNameObj = slot:FindFirstChild("ItemName")
        if itemNameObj and itemNameObj:IsA("StringValue") and itemNameObj.Value ~= "" then
            local tierName = ItemTiers[itemNameObj.Value]
            if tierName and TierSettings[tierName] then
                local settings = TierSettings[tierName]
                table.insert(foundItems, itemNameObj.Value)
                if settings.Priority > highestPriority then
                    highestPriority = settings.Priority
                    bestColor = settings.Color
                end
            end
        end
    end

    -- Update or Destroy Visuals
    local highlight = container:FindFirstChild("LootHighlight")
    local billboard = container:FindFirstChild("LootNametag")

    if #foundItems > 0 then
        if not highlight then
            highlight = Instance.new("Highlight")
            highlight.Name = "LootHighlight"
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
            highlight.FillTransparency = 0.5
            highlight.Parent = container
        end
        highlight.FillColor = bestColor 

        if not billboard then
            billboard = Instance.new("BillboardGui")
            billboard.Name = "LootNametag"
            billboard.StudsOffset = Vector3.new(0, 3, 0)
            billboard.AlwaysOnTop = true
            billboard.MaxDistance = math.huge 
            
            local textLabel = Instance.new("TextLabel")
            textLabel.Name = "ItemText"
            textLabel.Size = UDim2.new(1, 0, 1, 0)
            textLabel.BackgroundTransparency = 1
            textLabel.TextStrokeTransparency = 0
            textLabel.TextSize = 14
            textLabel.Font = Enum.Font.Code
            textLabel.TextYAlignment = Enum.TextYAlignment.Bottom
            textLabel.Parent = billboard
            
            billboard.Parent = container
        end
        
        billboard.Size = UDim2.new(0, 250, 0, 20 + (#foundItems * 15))
        local textLabel = billboard:FindFirstChild("ItemText")
        if textLabel then
            textLabel.TextColor3 = bestColor
            textLabel.Text = table.concat(foundItems, "\n")
        end
    else
        if highlight then highlight:Destroy() end
        if billboard then billboard:Destroy() end
    end
end

-- Processes an ItemName StringValue when it loads into the game
local function onItemNameAdded(itemNameObj)
    if HookedItems[itemNameObj] then return end
    HookedItems[itemNameObj] = true

    -- Safely clear tracking if this item streams out
    itemNameObj.AncestryChanged:Connect(function(_, newParent)
        if not newParent then HookedItems[itemNameObj] = nil end
    end)

    -- Find the container this item belongs to
    local slot = itemNameObj.Parent
    local slotsFolder = slot and slot.Parent
    local container = slotsFolder and slotsFolder.Parent

    if container then
        -- Run an immediate check
        task.defer(function()
            evaluateContainer(container)
        end)

        -- Listen for player taking the item
        itemNameObj:GetPropertyChangedSignal("Value"):Connect(function()
            evaluateContainer(container)
        end)
    end
end

