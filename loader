local SerID = nil
local VLabel = nil

-- Automatically hooks back onto the UI after you respawn and re-applies formatting
local function updateUIReferences()
    if VLabel and VLabel:IsDescendantOf(game) and SerID and SerID:IsDescendantOf(game) then
        return true -- References are still healthy and valid
    end

    local PlayerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
    if not PlayerGui then return false end

    local StatusIndicator = PlayerGui:FindFirstChild("StatusIndicator")
    local MoneyFrame = StatusIndicator and StatusIndicator:FindFirstChild("MoneyFrame")
    
    if MoneyFrame then
        SerID = MoneyFrame:FindFirstChild("ServerID")
        if SerID then
            SerID.Text = "Server ID: 0000-0000"
        end

        local TargetLabel = MoneyFrame:FindFirstChild("VersionLabel")
        if TargetLabel then
            VLabel = TargetLabel
            VLabel.Position = UDim2.new(0, 0, 1.5, 0)
            VLabel.Size = UDim2.new(1, 0, 15, 0)
            VLabel.TextYAlignment = Enum.TextYAlignment.Top
            VLabel.TextXAlignment = Enum.TextXAlignment.Left
            VLabel.TextStrokeTransparency = 0
            VLabel.TextTransparency = 0
            return true
        end
    end
    return false
end

