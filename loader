local player = Players.LocalPlayer
local savedCFrame = nil

local function getHRP()
    local character = player.Character or player.CharacterAdded:Wait()
    return character:WaitForChild("HumanoidRootPart")
end

UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
    if gameProcessedEvent then return end

    if input.KeyCode == Enum.KeyCode.KeypadOne then
        local hrp = getHRP()
        savedCFrame = hrp.CFrame

    elseif input.KeyCode == Enum.KeyCode.KeypadTwo then
        if not savedCFrame then return end

        ReplicatedStorage.AllowRespawn:FireServer()

        -- Wait for a fresh character, but don't hang forever if none comes
        local newCharacter = player.Character
        local success = pcall(function()
            newCharacter = player.CharacterAdded:Wait()
        end)

        local hrp = getHRP()
        task.wait(0.3) -- let physics settle after spawn
        hrp.CFrame = savedCFrame
    end
end)

