-- 6. BOT TRACKING ENGINE (ESP & HITBOX)
-- ============================================================================
local targetName = "Tyrant"

local function setupESP(bot)
    local hl = bot:FindFirstChild("BotHighlight")

    if not hl then
        hl = Instance.new("Highlight")
        hl.Name = "BotHighlight"
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent = bot
    end

    hl.FillColor = Color3.fromRGB(255, 40, 40)
    hl.OutlineColor = Color3.fromRGB(255, 40, 40)
    hl.FillTransparency = 0.55
    hl.OutlineTransparency = 0
end

local function setupNameHealthESP(bot)
    local head = bot:FindFirstChild("Head")
    local humanoid = bot:FindFirstChild("Humanoid")
    if not head or not humanoid then return end

    local old = head:FindFirstChild("BotTextESP")
    if old then
        old:Destroy()
    end

    local maxHealth = 10000

    local bb = Instance.new("BillboardGui")
    bb.Name = "BotTextESP"
    bb.AlwaysOnTop = true
    bb.Size = UDim2.new(0, 200, 0, 54)
    bb.StudsOffset = Vector3.new(0, 3.5, 0)
    bb.ResetOnSpawn = false
    bb.Parent = head

    local frame = Instance.new("Frame")
    frame.Size = UDim2.fromScale(1,1)
    frame.BackgroundColor3 = Color3.fromRGB(5,10,20)
    frame.BackgroundTransparency = 0.18
    frame.BorderSizePixel = 0
    frame.Parent = bb

    Instance.new("UICorner", frame).CornerRadius = UDim.new(0,7)

    local accent = Instance.new("Frame")
    accent.Size = UDim2.new(0,4,1,0)
    accent.BackgroundColor3 = Color3.fromRGB(255,40,40)
    accent.BorderSizePixel = 0
    accent.Parent = frame

    Instance.new("UICorner", accent).CornerRadius = UDim.new(0,4)

    local name = Instance.new("TextLabel")
    name.BackgroundTransparency = 1
    name.Position = UDim2.new(0,8,0,4)
    name.Size = UDim2.new(1,-12,0,20)
    name.Font = Enum.Font.GothamBold
    name.TextSize = 13
    name.TextColor3 = Color3.fromRGB(255,40,40)
    name.TextXAlignment = Enum.TextXAlignment.Left
    name.Text = "☠ "..bot.Name
    name.Parent = frame

    local hp = Instance.new("TextLabel")
    hp.BackgroundTransparency = 1
    hp.Position = UDim2.new(0,8,0,24)
    hp.Size = UDim2.new(1,-12,0,18)
    hp.Font = Enum.Font.Gotham
    hp.TextSize = 11
    hp.TextXAlignment = Enum.TextXAlignment.Left
    hp.Parent = frame

    local function update(health)
        local pct = math.clamp(health / maxHealth,0,1)
        hp.Text = string.format("❤ %d / %d", math.floor(health), maxHealth)
        hp.TextColor3 = Color3.fromHSV(pct * 0.33,1,1)
    end

    update(humanoid.Health)
    humanoid.HealthChanged:Connect(update)
end

local function expandHitbox(bot)
    local head = bot:FindFirstChild("Head")
    if head then
        head.Size = Vector3.new(10, 10, 10)
        head:GetPropertyChangedSignal("Size"):Connect(function()
            if head.Size ~= Vector3.new(10, 10, 10) then
                head.Size = Vector3.new(10, 10, 10)
                head.Transparency = 1
                local face = head:FindFirstChild("face")
                if face then face.Transparency = 1 end
            end
        end)
    end
end

local function processBot(model)
    if model.Name == targetName then
        setupESP(model)
        expandHitbox(model)
        setupNameHealthESP(model)
    end
end

local botsFolder = Workspace:WaitForChild("Bots", 5)
if botsFolder then
    for _, child in ipairs(botsFolder:GetChildren()) do
        processBot(child)
    end
    botsFolder.ChildAdded:Connect(processBot)
end

task.spawn(function()
    while true do
        task.wait(3)

        if botsFolder then
            for _, bot in ipairs(botsFolder:GetChildren()) do
                if bot.Name == targetName then
                    setupESP(bot)
                    setupNameHealthESP(bot)
                    expandHitbox(bot)
                end
            end
        end
    end
end)

