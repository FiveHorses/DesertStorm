local function getClosestPlayerToCursor()
    local mouseLocation = UserInputService:GetMouseLocation()
    local closestPlayer = nil
    local shortestDistance = math.huge

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local vector, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    local distance = (Vector2.new(vector.X, vector.Y) - mouseLocation).Magnitude
                    if distance < shortestDistance then
                        shortestDistance = distance
                        closestPlayer = p
                    end
                end
            end
        end
    end
    return closestPlayer
end

local function getInventoryString(p)
    local text = p.DisplayName .. "'s Equipment:\n\n"
    local inventory = p:FindFirstChild("Inventory")
    
    if inventory then
        local equipment = inventory:FindFirstChild("Equipment")
        if equipment then
            local items = equipment:GetChildren()
            if #items == 0 then
                text = text .. "- (Empty)"
            else
                for _, item in ipairs(items) do
                    local nameStr = item.Name
                    local itemNameVal = item:FindFirstChild("ItemName")
                    
                    if itemNameVal and itemNameVal:IsA("StringValue") then
                        nameStr = itemNameVal.Value
                    elseif item:IsA("StringValue") then
                        nameStr = item.Value
                    end
                    text = text .. "- " .. nameStr .. "\n"
                end
            end
        else
            text = text .. "Gun"
        end
    else
        text = text .. "Weapon"
    end
    return text
end

local function getHighestTierForPlayer(p)
    local inv = p:FindFirstChild("Inventory")
    if not inv then return nil end

    local highestPriority = 0
    local targetTier = nil

    local function checkItem(itemInstance)
        local itemName = itemInstance.Name
        local nameVal = itemInstance:FindFirstChild("ItemName")
        
        if nameVal and nameVal:IsA("StringValue") then
            itemName = nameVal.Value
        elseif itemInstance:IsA("StringValue") then
            itemName = itemInstance.Value
        end

        local tierName = ItemTiers[itemName]
        if tierName then
            local priority = TierSettings[tierName].Priority
            if priority > highestPriority then
                highestPriority = priority
                targetTier = tierName
            end
        end
    end

    local equipment = inv:FindFirstChild("Equipment")
    if equipment then
        for _, item in ipairs(equipment:GetChildren()) do
            checkItem(item)
        end
    end

    return targetTier
end

-- Hover UI update loop
local lastClosest = nil
local lastUpdate = 0
local THROTTLE_INTERVAL = 0.1 

local connection = RunService.RenderStepped:Connect(function()
    if not updateUIReferences() then return end
    
    local closest = getClosestPlayerToCursor()
    
    if closest then
        local now = os.clock()
        if closest ~= lastClosest or (now - lastUpdate) >= THROTTLE_INTERVAL then
            lastClosest = closest
            lastUpdate = now
            
            VLabel.Text = getInventoryString(closest) 
            local tier = getHighestTierForPlayer(closest)
            if tier then
                VLabel.TextColor3 = TierSettings[tier].Color
            else
                VLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end
    else
        if lastClosest ~= nil then
            lastClosest = nil
            VLabel.Text = ""
        end
    end
end)

