-- ============================================================================
getgenv().ItemNotifierActive = true
local notifiedCache = {} 

local function scanAllInventories()
    local currentItems = {}

    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local inv = p:FindFirstChild("Inventory")
        if not inv then continue end

        currentItems[p.Name] = {}

        local function processItem(itemInstance)
            local itemName = itemInstance.Name
            local nameVal = itemInstance:FindFirstChild("ItemName")
            
            if nameVal and nameVal:IsA("StringValue") then
                itemName = nameVal.Value
            elseif itemInstance:IsA("StringValue") then
                itemName = itemInstance.Value
            end

            local tier = ItemTiers[itemName]

            if tier then
                currentItems[p.Name][itemName] = true
                
                if not (notifiedCache[p.Name] and notifiedCache[p.Name][itemName]) then
                    local settings = TierSettings[tier]
                    
                    StarterGui:SetCore("SendNotification", {
                        Title = p.DisplayName,
                        Text = "[" .. tier .. "] " .. itemName .. " " .. settings.Icon,
                        Duration = 6
                    })
                end
            end
        end

        local equipment = inv:FindFirstChild("Equipment")
        if equipment then 
            for _, item in ipairs(equipment:GetChildren()) do 
                processItem(item) 
            end 
        end
    end

    notifiedCache = currentItems
end

task.spawn(function()
    while getgenv().ItemNotifierActive do
        scanAllInventories()
        task.wait(3)
    end
end)

getgenv().InvCheckerCleanup = function()
    connection:Disconnect()
    getgenv().ItemNotifierActive = false
    if VLabel and VLabel:IsDescendantOf(game) then VLabel.Text = "" end
    getgenv().InvCheckerCleanup = nil
end

