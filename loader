local containersFolder = workspace:WaitForChild("Containers", 10)

if containersFolder then
    -- 1. Scan everything currently loaded in
    for _, obj in ipairs(containersFolder:GetDescendants()) do
        if obj.Name == "ItemName" and obj:IsA("StringValue") then
            onItemNameAdded(obj)
        end
    end

    -- 2. Catch anything that streams in or is spawned later
    containersFolder.DescendantAdded:Connect(function(obj)
        if obj.Name == "ItemName" and obj:IsA("StringValue") then
            onItemNameAdded(obj)
        end
    end)
else
    warn("Could not find 'Containers' folder in the workspace!")
end
